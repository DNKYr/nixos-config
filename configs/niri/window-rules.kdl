// WezTerm initial-configure workaround (upstream-recommended).
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Firefox picture-in-picture floats by default.
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

// Alacritty opens maximized so Mod+F toggle returns to the same size.
window-rule {
    match app-id="Alacritty"
    open-maximized true
}

// Enable round-corners for all windows
window-rule {
	geometry-corner-radius 4
	clip-to-geometry true
}

