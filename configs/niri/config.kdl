// niri config — KDL format. Reference: https://yalter.github.io/niri/Configuration:-Introduction
// Only non-default settings are kept here. Everything omitted falls back to niri's built-in defaults.

include "binds.kdl"
include "window-rules.kdl"
input {
    keyboard {
        repeat-delay 200
        repeat-rate 35
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    focus-follows-mouse max-scroll-amount="0%"
}

spawn-sh-at-startup "sleep 1 && noctalia-shell"

prefer-no-csd
